<https://data.go.kr/dataset/15000484> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    aird:isStandardDataset false ;
    aird:nextUpdateDate "2025-11-21"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "이 데이터는 서귀포시 내에서 물가 안정과 소비자 부담 완화를 위해 “착한가격업소”로 지정된 업소들의 정보(업종, 업소명, 주소, 연락처, 제공 품목, 위치좌표 등)를 모아놓은 자료입니다. 행정기관은 이 데이터를 활용해 저소득자나 관광객의 접근성이 좋은 착한가격업소 분포를 분석하고, 가격·품질 비교 지도를 통해 거리 기반 소비자 추천 서비스를 만들 수 있어요. 또한 업종별 업소 밀집 지역과 공백 지역을 시각화해 물가 안정 관련 정책을 집중 지원할 지역을 선정하거나, 소비자에게는 거주지 근처 또는 이동 동선 상에서 신뢰할 수 있는 가격 우수 업소를 쉽게 찾는 데 유용합니다. 품목 정보까지 포함되어 있어서 어떤 서비스나 음식 가격이 ‘착한가격업소’ 기준에 해당하는지 판단하는 데 도움이 되고, 외식업·이미용업·세탁업 등 서비스업 중심 업소들의 가격·품질 경쟁력에 대한 연구 자료로도 쓸만해요."@ko ;
    dct:identifier "15000484" ;
    dct:issued "2019-08-12"^^xsd:date ;
    dct:modified "2025-09-15"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/6520000> ;
    dct:title "제주특별자치도 서귀포시_착한가격업소정보"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 4792 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 1616 ] ;
    rdfs:comment "연락처(D열), 휴무일(E열) 공란사유: 데이터 미집계, 개인정보 포함"@ko ;
    dcat:contactPoint [ a vcard:Organization ;
            vcard:fn "서귀포시 디지털혁신과"@ko ;
            vcard:hasTelephone <tel:0647602283> ] ;
    dcat:distribution <https://data.go.kr/dataset/15000484/distribution> ;
    dcat:keyword "가격비교"@ko,
        "가격우수업소"@ko,
        "물가안정"@ko,
        "서비스"@ko,
        "소비자편의"@ko,
        "외식업체"@ko,
        "우수업소"@ko,
        "착한가격"@ko ;
    dcat:landingPage <https://www.data.go.kr/data/15000484/fileData.do> ;
    dcat:theme <https://data.go.kr/theme/관광> .

