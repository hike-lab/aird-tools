    ],
    "http://datahub.kr/ns/aird#nextUpdateDate": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-05-28"
      }
    ],
    "http://purl.org/dc/terms/accrualPeriodicity": [
      {
        "@id": "http://publications.europa.eu/resource/authority/frequency/ANNUAL"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "ko",
        "@value": "성남시 보유 문화재에 대한 데이터이며, 구분,지정번호,명칭,소유자,소재지,관리단체의 항목으로 구성되어 있습니다. 성남시는 도시화가 빠르게 진행된 지역임에도 불구하고, 역사적 가치를 지닌 국가 지정 및 시 지정 문화재를 다수 보유하고 있다. 국가문화유산포털 기준으로 성남시에는 보물, 사적, 중요무형문화재 등 다양한 유형의 국가유산이 존재한다. 불교 문화유산, 전통 가옥 등도 문화재로 지정되어 있다. 성남시는 문화재의 보존·정비는 물론, 역사문화 탐방로 조성, 해설사 운영, 시민 참여 프로그램 등을 통해 지역문화유산을 적극적으로 활용하고 있습니다."
      }
    ],
