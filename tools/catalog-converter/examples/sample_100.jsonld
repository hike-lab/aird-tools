  {
    "@id": "https://data.go.kr/dataset/15000635",
    "@type": [
      "http://www.w3.org/ns/dcat#Dataset"
    ],
    "http://datahub.kr/ns/aird#isNationalCoreDataset": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
    "http://purl.org/dc/terms/accrualPeriodicity": [
      {
        "@id": "http://publications.europa.eu/resource/authority/frequency/IRREG"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "ko",
        "@value": "성남시의 마을버스 노선 대장에 대한 데이터로 노선번호, 노선유형, 기점, 경유지, 총점, 운행거리 등의 항목을 제공합니다. ‘경기도 성남시_마을버스 노선대장 목록정보’ 데이터는 성남시에서 운행 중인 마을버스 노선의 기본 구조와 세부 정보를 체계적으로 정리한 자료입니다. 이 데이터에는 운영에 필요한 핵심 정보가 포함되어 있습니다. 또한 노선별 정류장 위치, 운영 업체, 운행 회차와 같은 세부 내용도 제공하여 시민들이 대중교통을 효율적으로 이용할 수 있도록 돕습니다. 행정적으로는 교통 취약지역 발굴, 노선 조정 및 개선, 대중교통 서비스 품질 향상 등을 위한 기초자료로 적극 활용될 수 있습니다. 이를 통해 성남시의 생활권 교통 환경을 이해하고, 보다 편리하고 안전한 마을버스 운행체계를 구축하는 데 중요한 역할을 하는 데이터입니다."
      }
    ],
    "http://purl.org/dc/terms/identifier": [
      {
        "@value": "15000635"
      }
    ],
