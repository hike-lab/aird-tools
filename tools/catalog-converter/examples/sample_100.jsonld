  {
    "@id": "https://data.go.kr/dataset/15001318",
    "@type": [
      "http://www.w3.org/ns/dcat#Dataset"
    ],
    "http://datahub.kr/ns/aird#isNationalCoreDataset": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
