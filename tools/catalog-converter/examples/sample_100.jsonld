    "http://datahub.kr/ns/aird#nextUpdateDate": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-05"
      }
    ],
    "http://purl.org/dc/terms/accrualPeriodicity": [
      {
        "@id": "http://publications.europa.eu/resource/authority/frequency/ANNUAL"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "ko",
        "@value": "성남시 내 노인지회 현황에 대한 데이터로, 소재지,노인수,회원수,경로당수,전화번호 등의 항목으로 구성되어 있습니다. 성남시에는 어르신들의 권익 증진과 사회 참여를 지원하기 위해 대한노인회 산하의 성남시지회와 구별(수정구·중원구·분당구) 분회 조직이 구성되어 활발히 운영되고 있다. 대한노인회 성남시지회는 각 구에 위치한 분회 및 다수의 경로당과 협력하여 지역 내 노인의 사회활동, 여가, 복지사업을 지원하며, 회원 수는 수천 명 규모에 달한다. 지회는 노인의 자원봉사, 평생교육, 건강증진 프로그램 등을 기획·운영하며, 지역 행사 참여와 세대통합 활동도 주관한다."
      }
    ],
    "http://purl.org/dc/terms/identifier": [
      {
        "@value": "15000753"
      }
    ],
