      }
    ],
    "http://purl.org/dc/terms/accrualPeriodicity": [
      {
        "@id": "http://publications.europa.eu/resource/authority/frequency/ANNUAL"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "ko",
        "@value": "이 데이터는 서산시 관내 자동차 대여업체의 기본 정보를 제공하는 공공자료이다. 수록 항목은 업체명, 대표자, 소재지, 전화번호, 위도, 경도로 구성되며, 지역 내 대여업소 파악과 시민 정보 제공을 목적으로 한다. 업체명은 등록된 명칭이며, 대표자는 실제 운영 책임자이다. 소재지는 사업장의 위치를 의미하고, 전화번호는 예약이나 문의를 위한 연락처이다. 위도와 경도는 지도 기반 검색과 위치 확인에 사용된다. 본 자료는 행정기관의 업소 관리, 시민의 대여업소 조회, 교통 정책 수립, 위치기반 앱 개발 등에 활용된다. 데이터는 최신 정보 유지를 위해 정기적으로 갱신되며, 서산시 교통 인프라 활용도 증대와 민간 서비스 개선에 기여하는 기반 자료이다."
      }
    ],
    "http://purl.org/dc/terms/identifier": [
      {
        "@value": "15000680"
      }
    ],
