<https://data.go.kr/dataset/15001486> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    aird:nextUpdateDate "2026-03-19"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "광주광역시에서는 지역에서 활동하는 측량업체를 등록하고 관리하고 있습니다. 측량업이란 땅이나 건물, 도로 등 위치와 경계를 정확하게 측정하는 일을 하는 업종을 말합니다. 우리 시에서 관리하는 측량업의 종류는 크게 세 가지로, ‘지적측량업’, ‘일반측량업’, ‘공공측량업’이 있습니다. 지적측량업은 토지의 경계와 면적을 정밀하게 측정하는 업무를, 일반측량업은 건설·토목 현장 등 다양한 분야의 측량을, 공공측량업은 국가나 지방자치단체가 발주하는 공공사업 측량을 주로 담당합니다. 이러한 업체들은 「공간정보의 구축 및 관리 등에 관한 법률」 제7절 제44조(측량업의 등록)에 따라 등록 기준을 충족해야만 영업이 가능합니다. 자료에는 각 업체별 측량업종, 등록번호, 등록일, 상호, 대표자 이름, 주된 영업소의 위치 등이 포함되어 있으며, 모든 정보는 K-GeoP 시스템(측량업 등록관리 시스템)을 통해 관리되고 있습니다. 이를 통해 시민들은 해당 업체가 합법적으로 등록된 곳인지 확인할 수 있고, 필요할 때 신뢰할 수 있는 측량 서비스를 받을 수 있습니다."@ko ;
    dct:identifier "15001486" ;
    dct:issued "2019-05-05"^^xsd:date ;
    dct:modified "2025-08-12"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/6290000> ;
    dct:references "공간정보의 구축및 관리 등에 관한 법률"@ko ;
    dct:title "광주광역시_측량업 등록현황"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 1789 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 5204 ] ;
    dcat:contactPoint [ a vcard:Kind ;
            vcard:fn "도시공간국 토지정보과"@ko ;
            vcard:hasTelephone <tel:0626134573> ] ;
    dcat:distribution <https://data.go.kr/dataset/15001486/distribution> ;
    dcat:keyword "공간정보"@ko,
        "공공측량업"@ko,
        "기업정보"@ko,
        "일반측량업"@ko,
        "지적측량업"@ko ;
    dcat:landingPage <https://www.data.go.kr/data/15001486/fileData.do> ;
    dcat:theme <https://data.go.kr/theme/국토관리>,
        <https://data.go.kr/theme/지역및도시> .

