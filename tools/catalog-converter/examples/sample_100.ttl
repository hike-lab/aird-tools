<https://data.go.kr/dataset/15000249> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    aird:nextUpdateDate "2026-09-22"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "본 자료는 법령의 제정·개정·폐지 및 행정규칙 작성에 필요한 절차, 기준, 역할 분담 등의 내용을 체계적으로 정리한 편람입니다. 구체적으로 안건 접수, 담당 검토, 의견수렴, 법제심사, 확정·공포까지의 전 과정을 단계별로 안내합니다. 또한 각 단계별 심사항목과 관련 사례를 제시하여 실무자의 이해를 돕고 일관된 법제 운영을 지원합니다. 조직 내부에서 법적 안정성을 확보하고 효율적인 법령 관리를 추진하는 데 기초 자료로 활용됩니다. 아울러 권한 주체 간 협업 구조를 명확히 설명하여 법무·행정 부서의 실무 역량을 제고합니다."@ko ;
    dct:identifier "15000249" ;
    dct:issued "2018-08-25"^^xsd:date ;
    dct:modified "2025-11-07"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/1170000> ;
    dct:spatial [ a dct:Location ;
            rdfs:label "대한민국"@ko ] ;
    dct:temporal [ a dct:PeriodOfTime ;
            rdfs:label "2024년"@ko ] ;
    dct:title "법제처_법제업무편람"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 1525 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 12407 ] ;
    dcat:contactPoint [ a vcard:Kind ;
            vcard:fn "국가법령정보센터"@ko ;
            vcard:hasTelephone <tel:0442006788> ] ;
    dcat:distribution <https://data.go.kr/dataset/15000249/distribution> ;
    dcat:keyword "국회심의"@ko,
        "내부지침"@ko,
        "법령심사"@ko,
        "심사기준"@ko,
        "입법절차"@ko,
        "적용사례"@ko,
        "절차안내"@ko,
        "행정절차"@ko ;
    dcat:landingPage <https://www.data.go.kr/data/15000249/fileData.do> ;
    dcat:theme <https://data.go.kr/theme/공공행정>,
        <https://data.go.kr/theme/법제> .

