<https://data.go.kr/dataset/15001640> a dcat:Dataset ;
    aird:collectionMethod "부동산종합공부시스템"@ko ;
    aird:isNationalCoreDataset false ;
    aird:nextUpdateDate "2026-03-24"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "광주광역시에서 관리하는 ‘지적기준점’은 토지 측량을 정확하게 하기 위해 설치된 기준점들입니다. 측량이란 땅의 위치와 경계를 정밀하게 재는 작업인데, 이때 기준점이 매우 중요합니다. 지적기준점은 「공간정보의 구축 및 관리 등에 관한 법률」에 따라 정해진 공식 측량 기준점으로, 광주광역시 5개 자치구(동구, 서구, 남구, 북구, 광산구)에 걸쳐 관리되고 있습니다. 지적기준점은 크게 세 가지 종류가 있습니다. 첫째, ‘지적삼각점’은 국가기준점을 기준으로 하여 만든 주요 기준점으로, 수평 위치를 측정할 때 기본이 됩니다. 둘째, ‘지적삼각보조점’은 국가기준점과 지적삼각점을 바탕으로 만든 보조 기준점으로, 측량의 정확도를 높이는 역할을 합니다. 셋째, ‘지적도근점’은 앞서 설명한 기준점들과 다른 도근점을 참고하여, 각 필지의 정확한 위치를 측정할 때 사용하는 기준점입니다. 이러한 지적기준점들은 토지의 위치와 경계를 명확히 해 부동산 거래, 개발, 토지 관리 등 여러 분야에서 신뢰할 수 있는 기준 역할을 합니다. 시민들은 이 기준점 덕분에 자신의 땅 위치를 정확히 알 수 있고, 불필요한 경계 분쟁을 줄이는 데 도움을 받을 수 있습니다. 광주시는 이 기준점들을 체계적으로 관리하며, 공간 정보의 정확성과 신뢰성을 높이기 위해 노력하고 있습니다."@ko ;
    dct:identifier "15001640" ;
    dct:issued "2020-04-03"^^xsd:date ;
    dct:modified "2025-08-12"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/6290000> ;
    dct:references "공간정보의 구축 및 관리등에 관한 법률 시행령 제8조"@ko ;
    dct:title "광주광역시 지적측량기준점 정보"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 1149 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 4824 ] ;
    dcat:contactPoint [ a vcard:Kind ;
            vcard:fn "도시공간국 토지정보과"@ko ;
            vcard:hasTelephone <tel:0626134573> ] ;
    dcat:distribution <https://data.go.kr/dataset/15001640/distribution> ;
    dcat:keyword "공간정보"@ko,
        "지적기준점"@ko,
        "지적도근점"@ko,
        "지적삼각점"@ko,
        "지적측량"@ko ;
    dcat:landingPage <https://www.data.go.kr/data/15001640/fileData.do> ;
    dcat:theme <https://data.go.kr/theme/국토관리>,
        <https://data.go.kr/theme/지역및도시> .

