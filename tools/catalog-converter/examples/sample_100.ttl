<https://data.go.kr/dataset/15000543> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    aird:nextUpdateDate "2027-02-05"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "전라남도 해남군 소재 숙박업소 현황에 관한 데이터입니다. 이 데이터에는 업종명, 숙박업소 명칭, 업태, 숙박업소 연락처, 숙박업소 소재지, 객실 수 항목에 대한 정보를 제공합니다. 26년 2월 기준 총 78개소의 숙박업소가 있습니다. 해남읍에 28개소로 가장 많이 있으며, 두륜산 및 대흥사가 있는 삼산면은 15개소, 송호해수욕장 등이 있는 송지면 13개소, 우수영관광지가 있는 문내면 10개소 등의 순입니다. 해남군 문화관광 홈페이지에서 숙박업소 관련 사진, 서비스 제공 여부 등 다양한 정보를 얻을 수 있습니다."@ko ;
    dct:identifier "15000543" ;
    dct:issued "2019-07-29"^^xsd:date ;
    dct:modified "2026-02-09"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/4930000> ;
    dct:references "공중위생관리법"@ko ;
    dct:title "전라남도 해남군_숙박업소"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 5831 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 975 ] ;
    rdfs:comment "공란은 정보없음"@ko ;
    dcat:contactPoint [ a vcard:Kind ;
            vcard:fn "총무과"@ko ;
            vcard:hasTelephone <tel:0615305461> ] ;
    dcat:distribution <https://data.go.kr/dataset/15000543/distribution> ;
    dcat:keyword "공중위생"@ko,
        "모텔"@ko,
        "숙박"@ko,
