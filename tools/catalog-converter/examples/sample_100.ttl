<https://data.go.kr/dataset/15001644> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:description "한국가스안전공사에서 대형 가스사고를 예방하고자 관리하고 있는 독성가스에 대한 정보를 사용량, 제조량, 수입량에 따라 구분하여 제공하는 데이터입니다. 해당 데이터는 연도별 액화가스와 압축가스의 사용량, 제조량, 수입량으로 구성되어 있습니다. 국내 독성가스 유통량 현황을 통하여 독성가스로 인한 가스사고를 예방 및 관리하는데 활용할 수 있습니다. ※ 해당 정보는 2013년에서 2018년 사이의 정보로 구성되어 있습니다. ※ 해당 정보는 타 유관기관에서 자체 수집, 관리를 통해 제공하는 정보와 일부 상이할 수 있음을 참고 바랍니다. -데이터 기준일자 : 2018년 12월 31일"@ko ;
    dct:identifier "15001644" ;
    dct:issued "2020-03-30"^^xsd:date ;
    dct:modified "2025-07-24"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/B410019> ;
    dct:references "고압가스안전관리법"@ko ;
    dct:title "한국가스안전공사_국내 독성가스 유통 정보"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
