<https://data.go.kr/dataset/15000444> a dcat:Dataset ;
    aird:isNationalCoreDataset false ;
    aird:nextUpdateDate "2026-05-30"^^xsd:date ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/ANNUAL> ;
    dct:description "성남시 산후조리원현황은 출산 직후 산모와 신생아의 건강을 돌보기 위한 산후조리원이 지역 내에 얼마나 존재하며, 어떤 조건으로 운영되고 있는지를 파악한 자료입니다. 산후조리원현황은 구별, 동별, 산후조리원 이름, 산후조리원 주소, 전화번호, 산후조리원 허가일자, 임산부 정원(인원), 영유아 정원(인원), 임산부실 면적, 영유아실 면적, 모유수유실 면적, 간호사 인원, 간호조무사 인원 등의 정보를 현행화하여 제공하고 있습니다. 산후조리원은 「모자보건법」에 따라 일정 기준을 충족해야 등록이 가능합니다."@ko ;
    dct:identifier "15000444" ;
    dct:issued "2018-03-19"^^xsd:date ;
    dct:modified "2025-05-30"^^xsd:date ;
    dct:publisher <https://data.go.kr/org/3780000> ;
    dct:title "경기도 성남시 산후조리원현황"@ko ;
    dct:type <https://data.go.kr/type/FILE> ;
    schema1:interactionStatistic [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:DownloadAction ;
            schema1:userInteractionCount 2720 ],
        [ a schema1:InteractionCounter ;
            schema1:interactionType schema1:ViewAction ;
            schema1:userInteractionCount 8469 ] ;
    dcat:contactPoint [ a vcard:Kind ;
            vcard:fn "정책기획과"@ko ;
            vcard:hasTelephone <tel:03115773100> ] ;
    dcat:distribution <https://data.go.kr/dataset/15000444/distribution> ;
    dcat:keyword "모자보건"@ko,
        "산후케어"@ko,
        "산후회복"@ko,
        "신생아케어"@ko,
        "임산부"@ko,
        "출산"@ko ;
    dcat:landingPage <https://www.data.go.kr/data/15000444/fileData.do> ;
    dcat:theme <https://data.go.kr/theme/보건의료> .

